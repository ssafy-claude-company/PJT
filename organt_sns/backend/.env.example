# Organt SNS — 환경변수 예시 (NF1302). 실제 비밀은 .env에만 두고 .env는 커밋하지 않는다.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:5173

# Organt 두뇌(협업 엔진) 위치 — ingest가 logs/flow.jsonl·audit.jsonl을 읽는다
ORGANT_PJT=/home/user/PJT

# 생성형 AI (F1302 + 심화). GMS 등 OpenAI 호환 엔드포인트. 실제 키는 .env에만.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4o-mini
