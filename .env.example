# --- Discord 봇 토큰 ---
# System 봇: 관리자 권한. 채널 감시·상태블록 게시·라우팅 담당(SYS의 손).
SYSTEM_BOT=

# --- 대상 채널 ---
# User의 [Request]를 받을 Discord 채널 ID
CHANNEL_ID=

# --- Organt 로스터 ---
# "토큰_환경변수명:역할" 을 쉼표로 나열한다. 첫 항목이 리더(담당).
# 토큰 값 자체는 아래처럼 각 환경변수에 따로 둔다(시크릿 분리).
ORGANT_ROSTER=TEST_BOT_1:담당자,TEST_OBT_2:프론트엔드,TEST_OBT_3:디자인
TEST_BOT_1=
TEST_OBT_2=
TEST_OBT_3=
# (ORGANT_ROSTER 미설정 시 TEST_BOT 단독 리더로 폴백)
# TEST_BOT=

# --- Organt(LLM) 모델 ---
# 비우면 SDK 기본(최신 Opus)을 사용한다. 예) opus, sonnet, haiku
ORGANT_MODEL=opus
