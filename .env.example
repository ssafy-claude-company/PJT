# --- Discord 봇 토큰 ---
# System 봇: 관리자 권한. 채널 감시·상태블록 게시·라우팅 담당(SYS의 손).
SYSTEM_BOT=

# --- 대상 채널 ---
# User의 [Request]를 받을 Discord 채널 ID
CHANNEL_ID=

# --- Organt 로스터 ---
# "토큰_환경변수명:역할설명" 을 ';' 로 나열한다(역할설명에 쉼표·괄호 OK). 첫 항목이 리더(담당).
# 역할설명이 구체적일수록 리더가 적절히 위임한다(예: 디자이너=스펙 제공, 프론트=스펙대로 CSS).
# 토큰 값 자체는 아래처럼 각 환경변수에 따로 둔다(시크릿 분리).
ORGANT_ROSTER=TEST_BOT_1:담당자(백엔드 API·데이터 직접 구현, 팀 리딩); TEST_OBT_2:프론트엔드(HTML/JS와 CSS 작성, 디자이너 스펙대로 화면 구현); TEST_OBT_3:디자이너(컬러/타이포/레이아웃/컴포넌트 등 디자인 결정을 '디자인 스펙 문서'로 제공, CSS는 직접 쓰지 않고 프론트가 구현)
TEST_BOT_1=
TEST_OBT_2=
TEST_OBT_3=
# (ORGANT_ROSTER 미설정 시 TEST_BOT 단독 리더로 폴백)
# TEST_BOT=

# --- Organt(LLM) 모델 ---
# 비우면 SDK 기본(최신 Opus)을 사용한다. 예) opus, sonnet, haiku
ORGANT_MODEL=opus
