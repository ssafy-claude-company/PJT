# --- Discord 봇 토큰 ---
# System 봇: 관리자 권한. 채널 감시·상태블록 게시·라우팅 담당(SYS의 손).
SYSTEM_BOT=

# --- 대상 채널 ---
# User의 [Request]를 받을 Discord 채널 ID
CHANNEL_ID=

# --- Organt 로스터(채용 풀) ---
# "토큰_환경변수명:역할" 을 ';' 로 나열한다. 역할엔 '맨 도메인 정체성'만 적는다(백엔드/프론트엔드/
# 디자이너/QA 등). **'담당자'는 라벨에 박지 않는다** — 담당자는 고정 직책이 아니라 그 [Request]의 To로
# 지정된 사람이며(흐름마다 다를 수 있음), 시스템이 To 수신자를 그 흐름의 담당자(리더)로 띄운다. 같은 봇이
# 한 흐름에선 담당자, 다른 흐름에선 한 직원으로 참여한다. 누가 무엇을·어떻게·인터페이스·분배는 라벨에
# 박지 말 것(런타임 협의로 정해짐). 한 도메인에 여러 명을 둬도 된다(중요·과중할수록 여러 명).
#
# '예비'(직군 미배정)는 채용 대기 인력이다: 로스터에 없는 전문 직군(게임 기획자·UX 디자이너·사운드 등)이
# 필요하면 런타임에 recruit(role='직군명')으로 예비를 그 직군으로 채용해 합류시킨다. 예비는 첫 '전원 기획'엔
# 안 들어가고 필요할 때만 합류한다. 예비 토큰을 더 넣을수록 더 다양한 직군을 채용할 수 있다.
ORGANT_ROSTER=ORGANT_BOT_2:백엔드; ORGANT_BOT_3:백엔드; ORGANT_BOT_4:프론트엔드; ORGANT_BOT_5:프론트엔드; ORGANT_BOT_6:디자이너; ORGANT_BOT_7:QA; ORGANT_BOT_8:예비; ORGANT_BOT_9:예비; ORGANT_BOT_10:예비; ORGANT_BOT_11:예비; ORGANT_BOT_12:예비; ORGANT_BOT_13:예비
ORGANT_BOT_2=
ORGANT_BOT_3=
ORGANT_BOT_4=
ORGANT_BOT_5=
ORGANT_BOT_6=
ORGANT_BOT_7=
# 예비(채용 대기) — 토큰을 넣은 만큼 활성화(빈 슬롯은 자동 제외). 더 필요하면 슬롯을 늘린다.
ORGANT_BOT_8=
ORGANT_BOT_9=
ORGANT_BOT_10=
ORGANT_BOT_11=
ORGANT_BOT_12=
ORGANT_BOT_13=
# (ORGANT_ROSTER 미설정 시 TEST_BOT 단독 리더로 폴백)
# TEST_BOT=

# --- Organt(LLM) 모델 ---
# 비우면 SDK 기본(최신 Opus)을 사용한다. 예) opus, sonnet, haiku
ORGANT_MODEL=opus
