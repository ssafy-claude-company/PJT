# --- Discord 봇 토큰 ---
# System 봇: 관리자 권한. 채널 감시·상태블록 게시·라우팅 담당(SYS의 손).
SYSTEM_BOT=

# --- 대상 채널 ---
# User의 [Request]를 받을 Discord 채널 ID
CHANNEL_ID=

# --- Organt 로스터 ---
# "토큰_환경변수명:역할" 을 ';' 로 나열한다. 첫 항목이 리더(담당자).
# 역할은 '맨 도메인 정체성'만 적는다(예: 담당자/백엔드/프론트엔드/디자이너/QA). 누가 무엇을 어떻게
# 하는지·인터페이스·산출물 분배는 라벨에 미리 박지 말 것 — 그건 런타임에 팀 협의로 정해진다(구조).
# 책임·권한(리더는 조율·판정 + 구현 가능, owner는 끝까지 책임 등)은 시스템(역할=leader/member·프롬프트·
# 도구)이 부여하므로 라벨에 쓰지 않는다. 토큰 값 자체는 아래처럼 각 환경변수에 따로 둔다(시크릿 분리).
ORGANT_ROSTER=TEST_BOT_1:담당자; TEST_OBT_2:백엔드; TEST_OBT_3:프론트엔드; TEST_OBT_4:디자이너; TEST_OBT_5:QA
TEST_BOT_1=
TEST_OBT_2=
TEST_OBT_3=
TEST_OBT_4=
TEST_OBT_5=
# (ORGANT_ROSTER 미설정 시 TEST_BOT 단독 리더로 폴백)
# TEST_BOT=

# --- Organt(LLM) 모델 ---
# 비우면 SDK 기본(최신 Opus)을 사용한다. 예) opus, sonnet, haiku
ORGANT_MODEL=opus
