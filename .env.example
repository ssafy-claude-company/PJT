# --- Discord 봇 토큰 ---
# System 봇: 관리자 권한. 채널 감시·상태블록 게시·라우팅 담당(SYS의 손).
SYSTEM_BOT=

# --- 대상 채널 ---
# User의 [Request]를 받을 Discord 채널 ID
CHANNEL_ID=

# --- Organt 로스터(채용 풀) ---
# "토큰_환경변수명:역할" 을 ';' 로 나열한다. 첫 항목이 리더(담당자) — 리더도 한 도메인을 직접 맡아
# 일하는 직원이다(조율만 하는 백수 아님). 역할은 '맨 도메인 정체성'만 적는다(담당자/백엔드/프론트엔드/
# 디자이너/QA 등). 누가 무엇을 어떻게 할지·인터페이스·분배는 라벨에 박지 말 것 — 런타임 협의로 정해진다.
# 이건 '채용 풀'이다: 한 도메인에 여러 명을 둬도 되고(중요·과중한 작업일수록 여러 명), 리더가 작업 무게를
# 보고 그중 필요한 만큼 팀에 배정한다(남는 인력은 recruit로 끌어쓴다). 책임·권한은 시스템이 부여한다.
ORGANT_ROSTER=TEST_BOT_1:담당자(백엔드); TEST_OBT_2:백엔드; TEST_OBT_3:프론트엔드; TEST_OBT_4:프론트엔드; TEST_OBT_5:디자이너; TEST_OBT_6:QA
TEST_BOT_1=
TEST_OBT_2=
TEST_OBT_3=
TEST_OBT_4=
TEST_OBT_5=
TEST_OBT_6=
# (ORGANT_ROSTER 미설정 시 TEST_BOT 단독 리더로 폴백)
# TEST_BOT=

# --- Organt(LLM) 모델 ---
# 비우면 SDK 기본(최신 Opus)을 사용한다. 예) opus, sonnet, haiku
ORGANT_MODEL=opus
